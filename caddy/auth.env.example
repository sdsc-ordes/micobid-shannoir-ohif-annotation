# Copy this file to caddy/auth.env (gitignored) and fill in the values.
#
#   cp caddy/auth.env.example caddy/auth.env
#
# Generate the bcrypt hash for your password with:
#
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
#
# Paste the output (a $2a$... string) as BASIC_AUTH_HASH below. No escaping —
# docker-compose reads this file with format: raw, so $ is kept literal.

BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=$2a$14$REPLACE_ME_WITH_OUTPUT_OF_HASH_COMMAND
